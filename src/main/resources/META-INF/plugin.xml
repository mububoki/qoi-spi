<idea-plugin>
    <id>com.github.mububoki.qoi-spi</id>
    <name>QOI Image Support</name>
    <vendor>mububoki</vendor>
    <description>QOI (Quite OK Image) format support for IntelliJ-based IDEs via ImageIO SPI.</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.platform.images</depends>

    <extensions defaultExtensionNs="com.intellij">
        <preloadingActivity
            implementation="com.github.mububoki.qoispi.QoiPreloader"/>
        <fileTypeOverrider
            implementation="com.github.mububoki.qoispi.QoiFileTypeOverrider"/>
    </extensions>
</idea-plugin>
